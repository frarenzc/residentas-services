# Residentas Services — public booking app
# Names only. Never commit real values.

# Public origin of THIS app (used to build return URLs).
# Local: http://localhost:3002   Production: https://services.residentas.com
NEXT_PUBLIC_SITE_URL=

# Base URL of the Guest Services application, which remains the source of truth
# for pricing, booking persistence, Stripe Checkout and webhooks.
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_.
# Local: http://localhost:3000
GUEST_SERVICES_BASE_URL=

# NOTE: this application intentionally holds NO Stripe secret, NO Supabase
# service-role key and NO internal staff API token. Payment and persistence
# authority stays in Guest Services.
